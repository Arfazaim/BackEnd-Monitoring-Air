# ── Database ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=data_air

# ── Server ─────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Security ───────────────────────────────────────
# Ganti dengan string acak yang kuat (min 32 karakter)
API_KEY=

# ── Telegram Notifications ─────────────────────────
# Dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=
# Dapatkan dari @userinfobot di Telegram
TELEGRAM_CHAT_ID=

# ── Alert Thresholds (opsional, sudah ada default) ─
# PH_MIN=6.5
# PH_MAX=8.5
# TURBIDITY_MAX=25
# TDS_MAX=500
# BATTERY_MIN=3.0
